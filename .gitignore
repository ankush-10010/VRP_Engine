# Ignore everything by default
*

# --- EXCLUSIONS (Files to Keep) ---
!*.py
!*.csv
!*.md
!*.bat
!requirements.txt
!Dockerfile
!docker-compose.yml
!.dockerignore
!*.pdf
# Removed !*.jpg from here to ignore resume.jpg

# Un-ignore all directories so git can traverse them
!*/

# Don't ignore the .gitignore file itself
!.gitignore

# --- SPECIFIC IGNORES ---
Lib/
legacy_scripts/
__pycache__/
*.pyc

# Added specifically as requested:
.env
frontend/.env
matrix_data_with_distance.json
resume.jpg